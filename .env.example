# =============================================================
# Bankai RAG Gateway - Environment Configuration
# =============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================

# Ollama (LLM backend)
# For WSL2: use Windows host IP (ip route show default | awk '{print $3}')
# For native Linux/Docker: use localhost or container name
OLLAMA_HOST=172.25.176.1
OLLAMA_PORT=11434
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_URL=http://172.25.176.1:11434/api/chat

# Qdrant (vector DB)
QDRANT_URL=http://127.0.0.1:6333

# OPA (policy engine)
OPA_URL=http://127.0.0.1:8181/v1/data/rag/authz/allow

# Docs directory
DOCS_DIR=./docs

# Keycloak (Identity Provider)
KEYCLOAK_JWKS_URL=http://localhost:8443/realms/bankai/protocol/openid-connect/certs
KEYCLOAK_ISSUER=http://localhost:8443/realms/bankai

# Guardrail Limits (optional)
# RATE_LIMIT_PER_MINUTE=15
# RATE_LIMIT_PER_HOUR=100
# MAX_INPUT_CHARS=4000
# MAX_OUTPUT_CHARS=8000
