# =============================================================
# LibreChat - Environment Configuration
# =============================================================
# Copy this file to .env and fill in your values:
#   cp librechat/.env.example librechat/.env
# =============================================================

HOST=0.0.0.0
PORT=3080
DOMAIN_CLIENT=http://localhost:3080
DOMAIN_SERVER=http://localhost:3080
MONGO_URI=mongodb://mongodb:27017/LibreChat
NO_INDEX=true

# Auth: Only Keycloak SSO (no email/password login)
ALLOW_REGISTRATION=false
ALLOW_SOCIAL_LOGIN=true
ALLOW_EMAIL_LOGIN=false
ALLOW_SOCIAL_REGISTRATION=true

# Keycloak OIDC
OPENID_CLIENT_ID=librechat
OPENID_CLIENT_SECRET=CHANGE_ME_librechat_client_secret
OPENID_ISSUER=http://localhost:8443/realms/bankai/.well-known/openid-configuration
OPENID_SESSION_SECRET=CHANGE_ME_random_session_secret
OPENID_SCOPE=openid profile email
OPENID_CALLBACK_URL=/oauth/openid/callback
OPENID_BUTTON_LABEL=Keycloak ile Giris
OPENID_USE_END_SESSION_ENDPOINT=true
OPENID_POST_LOGOUT_REDIRECT_URI=http://localhost:3080/login
OPENID_REUSE_TOKENS=true
NODE_TLS_REJECT_UNAUTHORIZED=0
OPENID_REQUIRED_ROLE_TOKEN_KIND=none

# Session & Security (CHANGE THESE IN PRODUCTION)
SESSION_EXPIRY=604800000
CREDS_KEY=CHANGE_ME_32_char_hex_key_here!!
CREDS_IV=CHANGE_ME_16_char
JWT_SECRET=CHANGE_ME_jwt_secret_in_production
JWT_REFRESH_SECRET=CHANGE_ME_jwt_refresh_secret_in_production

# Gateway API key (used as fallback, JWT is primary auth)
LIBRECHAT_API_KEY=sk-placeholder
