      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{ "expr": "sum(count_over_time({job=\"bankai-audit\"} [1m]))", "legendFormat": "istek/dk", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" }, "custom": { "fillOpacity": 30 } } }
    },
    {
      "title": "Engellenen Istekler / Dakika",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{ "expr": "sum(count_over_time({job=\"bankai-audit\", allowed=\"false\"} [1m]))", "legendFormat": "deny/dk", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "red" }, "custom": { "fillOpacity": 30 } } }
    },
    {
      "title": "DLP Tespitleri / Dakika",
