      "targets": [{ "expr": "sum by (user) (count_over_time({job=\"bankai-audit\"} [$__range]))", "legendFormat": "{{user}}", "refId": "A" }],
      "options": { "orientation": "horizontal" }
    },
    {
      "title": "Gruba Gore Istekler",
      "type": "barchart",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
